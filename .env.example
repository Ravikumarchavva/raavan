# ── Agent Framework — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# See CLAUDE.md for full documentation.
#
# RULE: Never add inline comments after integer values.
#   ✅ REDIS_SESSION_TTL=3600
#   ❌ REDIS_SESSION_TTL=3600  # seconds
# python-dotenv passes the whole line to Pydantic → ValidationError.

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# ── PostgreSQL (long-term memory + server data) ────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentdb

# ── Redis (short-term / session memory) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=3600

# ── Session Management ──────────────────────────────────────────────────────
SESSION_MAX_MESSAGES=200
SESSION_AUTO_CHECKPOINT=50

# ── Spotify OAuth (optional) ───────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/auth/spotify/callback

# ── Visual Builder (optional) ──────────────────────────────────────────────
ENABLE_BUILDER=true
